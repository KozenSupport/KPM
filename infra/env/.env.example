# KPM local development environment variables.
# Copy to .env.local or export these values in your shell. Do not commit real secrets.

KPM_NACOS_ADDR=127.0.0.1:8848
KPM_NACOS_ENABLED=false

KPM_DB_HOST=127.0.0.1
KPM_DB_PORT=5432
KPM_DB_NAME=kpm
KPM_DB_USER=kpm
KPM_DB_PASSWORD=kpm_dev_password

KPM_CACHE_HOST=127.0.0.1
KPM_CACHE_PORT=6379

KPM_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
KPM_OSS_BUCKET=xc-kozen-sh-fw
KPM_OSS_ROOT_PREFIX=KPM/
KPM_OSS_ACCESS_KEY_ID=
KPM_OSS_ACCESS_KEY_SECRET=
KPM_NACOS_JVM_XMS=64m
KPM_NACOS_JVM_XMX=192m
KPM_NACOS_JVM_XMN=32m
KPM_JAVA_TOOL_OPTIONS=-Xms32m -Xmx192m -XX:+UseG1GC
KPM_NACOS_JAVA_OPT_EXT=-Xms64m -Xmx192m -Xmn32m -XX:+UseSerialGC
KPM_DB_POOL_MAX_SIZE=5
KPM_DB_POOL_MIN_IDLE=1
