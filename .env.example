# KPM local port profile: use a dedicated 19xxx/14xxx host range to avoid conflicts with API Manager and other local projects.
# KPM one-command local deployment template.
# Copy this file to .env before running Docker Compose.

KPM_DB_NAME=kpm
KPM_DB_USER=kpm
KPM_DB_PASSWORD=kpm_dev_password
KPM_DB_PORT=15433

KPM_VALKEY_PORT=16380
KPM_NACOS_PORT=18848
KPM_NACOS_CONSOLE_PORT=18849
KPM_NACOS_GRPC_PORT=19848
KPM_NACOS_ADDR=nacos:8848
KPM_NACOS_ENABLED=true
KPM_NACOS_CONFIG_ENABLED=true
KPM_NACOS_NAMESPACE=public
KPM_NACOS_CONFIG_GROUP=DEFAULT_GROUP
KPM_NACOS_JVM_XMS=128m
KPM_NACOS_JVM_XMX=512m
KPM_NACOS_JVM_XMN=64m

KPM_GATEWAY_PORT=19080
KPM_IAM_PORT=19101
KPM_RESOURCE_PORT=19102
KPM_PROJECT_PORT=19103
KPM_CUSTOMER_PORT=19104
KPM_TASK_PORT=19105
KPM_ORDER_PORT=19106
KPM_FILE_PORT=19107
KPM_ANALYTICS_PORT=19108
KPM_INTEGRATION_PORT=19109
KPM_NOTIFICATION_PORT=19110
KPM_FRONTEND_PORT=14173
# Keep empty to send browser requests to the frontend origin. The frontend server proxies /api.
VITE_KPM_API_BASE=
# Used only when running Vite directly on the host; Docker Compose overrides it with gateway:8080.
KPM_DEV_PROXY_TARGET=http://127.0.0.1:19080

# UAT image release. Server deployment pulls these images; it does not compile source code.
KPM_IMAGE_REGISTRY=ghcr.io/kozensupport
KPM_IMAGE_TAG=latest
KPM_PUBLIC_PROTOCOL=http
KPM_PUBLIC_HOST=127.0.0.1

KPM_AUTH_ENABLED=true
KPM_RBAC_ENABLED=true
KPM_AUTH_TOKEN_SECRET=kpm-local-dev-secret-change-me
KPM_NOTIFICATION_REFRESH_INTERVAL_SECONDS=120
KPM_NOTIFICATION_PROCESSOR_INTERVAL_MS=15000
KPM_NOTIFICATION_MAIL_ENABLED=false
KPM_NOTIFICATION_MAIL_FROM=noreply@kozen.example

# OSS is managed by Nacos for services. Keep secrets out of git.
# kpm-file-service.yaml should define kpm.oss.enabled/access-key-id/access-key-secret/bucket/endpoint/root-prefix.
# For a fresh machine, fill the commented values below before the first compose startup;
# the nacos-config-publisher service will publish them into Nacos and back them up under .local/.
KPM_OSS_ENABLED=false
KPM_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
KPM_OSS_BUCKET=xc-kozen-sh-fw
KPM_OSS_ROOT_PREFIX=KPM/
# KPM_OSS_ACCESS_KEY_ID=
# KPM_OSS_ACCESS_KEY_SECRET=
KPM_OSS_DOWNLOAD_URL_EXPIRE_SECONDS=900
KPM_UPLOAD_MAX_FILE_SIZE=500MB
KPM_UPLOAD_MAX_REQUEST_SIZE=520MB

# Logging and observability
KPM_LOG_LEVEL_ROOT=INFO
KPM_LOG_LEVEL_APP=INFO
KPM_APP_LOGGING_ENABLED=true
KPM_CONTROLLER_LOG_ENABLED=true
KPM_RESPONSE_LOG_ENABLED=true
KPM_SERVICE_LOG_ENABLED=true
KPM_LOG_MAX_PAYLOAD_LENGTH=2000
KPM_LOG_PATH=/workspace/logs
KPM_LOG_MAX_FILE_SIZE=100MB
KPM_LOG_MAX_HISTORY=10
KPM_LOG_TOTAL_SIZE_CAP=2GB
KPM_ERROR_ALERT_ENABLED=false
KPM_ERROR_ALERT_THRESHOLD=5
KPM_ERROR_ALERT_WINDOW_SECONDS=60
KPM_ERROR_ALERT_COOLDOWN_SECONDS=300
KPM_ERROR_ALERT_MAIL_FROM=noreply@kozen.example
KPM_ERROR_ALERT_RECIPIENTS=[]

# SkyWalking is disabled by default. Enable when running compose with --profile observability.
# KPM_SKYWALKING_JAVA_AGENT_OPTIONS=-javaagent:/skywalking-agent/skywalking-agent.jar
KPM_SKYWALKING_JAVA_AGENT_OPTIONS=
KPM_SKYWALKING_COLLECTOR_BACKEND_SERVICES=skywalking-oap:11800
KPM_SKYWALKING_UI_PORT=19081

# Shared SMTP settings for password codes, portal codes, notifications and 500-error alert emails.
KPM_MAIL_HOST=
KPM_MAIL_PORT=587
KPM_MAIL_USERNAME=
KPM_MAIL_PASSWORD=
KPM_MAIL_SMTP_AUTH=true
KPM_MAIL_STARTTLS_ENABLE=true
KPM_MAIL_HEALTH_ENABLED=false
